record(motor,"$(SYS):$(SUB)")
{
    field(DESC,"z-axis control")
    field(DTYP,"asynMotor")
    field(DIR,"Pos")
    field(VELO,"10.0")
    field(VBAS,"0.1")
    field(ACCL,"0.1")
    field(ACCU,"$(ACCU=0)")
    field(BDST,"0")
    field(BVEL,"0")
    field(BACC,"0")
    field(OUT,"@asyn(motorExit,0)")
    field(MRES,"2e-4")
    field(ERES,"2e-4")
    field(PREC,"3")
    field(EGU,"mm")
    field(DHLM,"60")
    field(DLLM,"-60")
    field(TWV,"2")
    field(HVEL,"5.0")
}
